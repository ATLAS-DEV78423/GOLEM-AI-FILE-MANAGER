# Normalize line endings for cross-platform development.
# PowerShell scripts need CRLF; everything else uses LF.
* text=auto eol=lf
*.py text eol=lf
*.ps1 text eol=crlf
*.sh text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.spec text eol=lf

# Binary files
*.png binary
*.ico binary
*.exe binary
*.dmg binary
*.zip binary
*.tar.gz binary
*.db binary
*.pdf binary
